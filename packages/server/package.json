{
  "name": "@pluse/server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "pluse": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun --watch dist/server.js",
    "clean": "rimraf dist",
    "build:server": "bun build src/server.ts --outdir dist --target bun",
    "build:cli": "bun build src/cli.ts --outfile dist/cli.js --target bun",
    "build:wrapper": "node scripts/write-cli-wrapper.mjs",
    "build": "run-s clean build:server build:cli build:wrapper",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/__tests__"
  },
  "dependencies": {
    "@pluse/types": "workspace:*",
    "commander": "^12.1.0",
    "croner": "^10.0.1",
    "hono": "^4.6.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.5.13",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.6.0"
  }
}
